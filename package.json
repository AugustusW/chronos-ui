{
  "name": "chronos-ui",
  "version": "0.1.0",
  "description": "Bring Order to Time — a cross-platform desktop GUI for managing native OS schedulers.",
  "license": "Apache-2.0",
  "author": "The ChronosUI Authors",
  "type": "module",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "stage:schedmgr": "node scripts/build-schedmgr.mjs",
    "dist:mac": "npm run stage:schedmgr && npm run build && electron-builder --mac --arm64",
    "dist:win": "npm run stage:schedmgr && npm run build && electron-builder --win --x64"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@eslint/js": "^9.13.0",
    "@types/better-sqlite3": "^7.6.13",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/test-utils": "^2.4.6",
    "drizzle-kit": "^0.28.1",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.29.0",
    "globals": "^17.6.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0",
    "vite": "^5.4.0",
    "vite-plugin-static-copy": "^3.4.0",
    "vitest": "^2.1.0",
    "vue": "^3.5.0",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.1.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "drizzle-orm": "^0.36.4",
    "vue-router": "^4.6.4"
  },
  "build": {
    "appId": "com.augustusw.chronos-ui",
    "productName": "ChronosUI",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "out/main/migrations/**"
    ],
    "extraResources": [
      {
        "from": "resources/schedmgr",
        "to": "schedmgr",
        "filter": [
          "schedmgr",
          "schedmgr.exe"
        ]
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "publish": null,
    "mac": {
      "target": [
        "dmg"
      ],
      "defaultArch": "arm64",
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "afterSign": "scripts/notarize.mjs",
    "dmg": {
      "artifactName": "ChronosUI-${version}-${arch}.dmg"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "ChronosUI-Setup-${version}.exe"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AugustusW/chronos-ui.git"
  },
  "bugs": {
    "url": "https://github.com/AugustusW/chronos-ui/issues"
  },
  "homepage": "https://github.com/AugustusW/chronos-ui#readme"
}
